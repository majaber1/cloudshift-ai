# CloudShift AI - Environment Configuration
# Copy this to .env and update

# Application
APP_NAME="CloudShift AI"
APP_URL=http://localhost:3000

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ADMIN_EMAIL=admin@demo.com
ADMIN_PASSWORD=demo123

# Database
DATABASE_URL=postgresql://cloudshift:cloudshift123@postgres:5432/cloudshiftdb
POSTGRES_DB=cloudshiftdb
POSTGRES_USER=cloudshift
POSTGRES_PASSWORD=cloudshift123

# AI / Ollama
OLLAMA_BASE_URL=http://ollama:11434
# Change model here: qwen2.5:7b-instruct | llama3.1:8b | mistral:7b
OLLAMA_MODEL=qwen2.5:7b-instruct
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4096
AI_TIMEOUT_SECONDS=180

# Vector Database (ChromaDB)
CHROMADB_HOST=chromadb
CHROMADB_PORT=8001

# File Upload
MAX_FILE_SIZE_MB=100
UPLOAD_DIR=/app/uploads
ALLOWED_EXTENSIONS=pdf,docx,doc,txt,xlsx,csv

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME="CloudShift AI"

# Assessment Settings
DEFAULT_CATEGORIES=Compute,Storage,Network,Security,Identity,Backup,DR,Monitoring,Cost,Compliance
SCORING_MODEL=weighted_average

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
